/* Hero */

.hero{

height:100vh;

display:flex;
justify-content:center;
align-items:center;

padding:100px;

gap:70px;

}

.hero img{

width:350px;
height:350px;

border-radius:50%;

object-fit:cover;

box-shadow:0 15px 35px rgba(0,0,0,.2);

animation:float 4s infinite;

}

.hero-text{

max-width:600px;

}

.hero-text h3{

font-size:25px;
