/* Cards */

.grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(280px,1fr));

gap:30px;

}

.card{

background:white;

padding:35px;

border-radius:20px;

box-shadow:0 10px 25px rgba(0,0,0,.08);

transition:.3s;

}

.card:hover{

transform:translateY(-10px);

}

.card i{

font-size:40px;
color:#2563eb;
margin-bottom:20px;

}

.card h3{

margin-bottom:15px;

}

.card p{

line-height:1.8;
color:#666;

}

/* Skills */

.skills{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(180px,1fr));

gap:20px;

}

.skill{

background:white;

padding:20px;

text-align:center;

border-radius:15px;

font-weight:600;

box-shadow:0 8px 20px rgba(0,0,0,.08);

transition:.3s;

