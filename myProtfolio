.social i{

font-size:22px;

width:50px;
height:50px;

background:white;

display:flex;
justify-content:center;
align-items:center;

border-radius:50%;

box-shadow:0 10px 20px rgba(0,0,0,.1);

transition:.3s;

cursor:pointer;

}

.social i:hover{

background:#2563eb;
color:white;
transform:translateY(-6px);

}

/* Sections */

section{

